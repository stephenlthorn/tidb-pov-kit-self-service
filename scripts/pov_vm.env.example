# Script-only VM deployment env for TiDB PoV

# Repo source
POV_REPO_URL=https://github.com/stephenlthorn/tidb-pov-kit-self-service.git
POV_REPO_REF=main
POV_WORK_DIR=$HOME/tidb-pov-kit-self-service-runner

# Path to a local config.yaml with TiDB credentials
POV_CONFIG_SOURCE=/absolute/path/to/config.yaml

# Run behavior
POV_RUN_ARGS="--no-menu --no-wizard"
POV_ENFORCE_S3_UPLOAD=true

# S3 destination (required)
POV_S3_BUCKET=your-pingcap-results-bucket
POV_S3_PREFIX=tidb-pov
POV_S3_PROJECT=customer-acme
POV_S3_REGION=us-east-1

# Recommended hardening
POV_S3_EXPECTED_BUCKET_OWNER=123456789012
POV_S3_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/replace-me

# Optional: assume-role for short-lived credentials (instead of long-lived keys)
POV_S3_ROLE_ARN=
POV_S3_EXTERNAL_ID=
POV_S3_SESSION_NAME=tidb-pov-runner
POV_S3_SESSION_DURATION=3600

# Optional fallback static credentials (avoid when possible)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
