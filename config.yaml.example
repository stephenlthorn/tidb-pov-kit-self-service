# TiDB Cloud PoV Kit — Configuration
# Copy this file to config.yaml and fill in your values.

tidb:
  host:     "gateway01.us-west-2.prod.aws.tidbcloud.com"
  port:     4000
  user:     "<prefix>.root"
  password: "YOUR_PASSWORD"
  database: "test"
  ssl:      true

# Optional: configure a comparison target for side-by-side benchmarking.
# Current automated runner support: Aurora MySQL, MySQL, RDS MySQL, SingleStore.
# Other targets below can be captured for planning and future runner support.
comparison_db:
  enabled:  false
  target:   "aurora_mysql"  # aurora_mysql | mysql | rds_mysql | postgres | rds_postgres | aurora_postgres | microsoft_sql_server | singlestore
  label:    "Aurora MySQL"
  host:     "aurora-cluster.us-west-2.rds.amazonaws.com"
  port:     3306
  user:     "admin"
  password: "YOUR_PASSWORD"
  database: "pov_test"
  schema:   "public"        # postgres: public, sql server: dbo
  ssl:      false
  ssl_mode: "require"       # postgres: disable | require | verify-ca | verify-full
  sqlserver_driver: "ODBC Driver 18 for SQL Server"
  sqlserver_encrypt: true
  sqlserver_trust_server_certificate: false

# Tier metadata (wizard can update this automatically)
tier:
  selected: "serverless"   # serverless | essential | premium | dedicated | byoc

# Optional: run load generation in customer AWS account (cross-account AssumeRole).
# This keeps EC2/network run costs in customer account while summary artifacts
# can still be uploaded to control plane for shared visibility.
aws_runner:
  enabled: false
  launch_mode: "customer_assume_role"
  connectivity_mode: "private_endpoint"     # private_endpoint | public_endpoint
  aws_region: "us-east-1"
  customer_account_id: ""
  customer_assume_role_arn: "arn:aws:iam::<ACCOUNT_ID>:role/TidbPovCustomerRunnerLaunchRole"
  external_id: ""
  vpc_id: ""
  subnet_id: ""
  security_group_id: ""
  runner_instance_profile_name: "TidbPovRunnerInstanceRole"
  runner_role_arn: "arn:aws:iam::<ACCOUNT_ID>:role/TidbPovRunnerInstanceRole"
  instance_size: "medium"                   # small | medium | large
  allowed_instance_types: ["c7i.2xlarge", "c7i.4xlarge", "c7i.8xlarge"]
  max_instances_per_run: 8
  summary_upload_only: true
  run_timeout_minutes: 180

test:
  run_mode:             "validation" # validation | performance
  schema_mode:          "tidb_optimized"  # tidb_optimized | mysql_compatible
  data_scale:            "small"      # serverless default: small
  duration_seconds:      120
  concurrency_levels:    [8, 16, 32]
  pre_warm_enabled:      true
  pre_warm_duration_seconds: 120
  pre_warm_concurrency:  16
  warm_phase_enabled:    true
  warm_phase_duration_seconds: 300
  warm_phase_concurrency: 32
  ramp_duration_seconds: 300
  import_rows:           1000000
  workload_mix:          "mixed"      # mixed | read_heavy | write_heavy
  read_weight_multiplier: 1.0
  write_weight_multiplier: 1.0
  import_batch_size:      5000
  import_methods:         ["batched_insert", "load_data_infile", "import_into"]
  import_into_source_uri: ""          # Optional: s3://bucket/path/file.csv for TiDB Cloud IMPORT INTO
  import_source_size_gb:   0.0        # Optional: set when using remote source URI for GB/min calc

# Your production queries — validated in M0 and replayed in M1
# Leave empty to use only synthetic workload
customer_queries: []
# Example:
# customer_queries:
#   - name: "get_user"
#     sql:  "SELECT id, email FROM users WHERE id = ?"
#     params: [1]
#   - name: "recent_txns"
#     sql:  "SELECT * FROM transactions WHERE account_id = ? ORDER BY created_at DESC LIMIT 20"
#     params: [100]

# Enable or disable individual test modules
# Wizard will apply tier-aware defaults in results/config.resolved.yaml.
modules:
  customer_queries:  true
  baseline_perf:     true
  elastic_scale:     true
  high_availability: false   # Dedicated/BYOC only by default
  write_contention:  true
  htap:              false   # enable when TiFlash is provisioned
  online_ddl:        true
  mysql_compat:      true
  data_import:       true
  vector_search:     false   # optional AI track

# Pre-PoC intake state (written by setup/pre_poc_intake.py)
pre_poc:
  scenario_template: "oltp_migration"   # oltp_migration | htap_analytics | ai_vector

report:
  customer_name: "Acme Corp"
  se_name:       "Your Name — PingCAP Sales Engineering"

# TCO model inputs — adjust to match customer's actual environment
tco:
  data_size_gb:              1000
  annual_growth_pct:         40
  aurora_shards_year0:       4
  engineers_managing_shards: 2
  engineer_annual_cost:      180000
  sharding_eng_fraction:     0.25
