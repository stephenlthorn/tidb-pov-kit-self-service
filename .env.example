# Flask UI session secret
POV_UI_SECRET=change-me-to-a-long-random-value

# Persistent storage (recommended on Vercel): set one of these.
# DATABASE_URL takes priority, then POSTGRES_URL_NON_POOLING, then POSTGRES_URL.
DATABASE_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=

# AWS runner defaults (used to prefill UI/config if config.yaml omits values)
AWS_REGION=us-east-1
AWS_EXTERNAL_ID=tidbpov-56b91434026898ead6ec93666188eae8
AWS_CUSTOMER_ACCOUNT_ID=219248915861
AWS_CUSTOMER_ASSUME_ROLE_ARN=arn:aws:iam::219248915861:role/TidbPovCustomerRunnerLaunchRole
AWS_RUNNER_ROLE_ARN=arn:aws:iam::219248915861:role/TidbPovRunnerInstanceRole
AWS_RUNNER_INSTANCE_PROFILE_NAME=TidbPovRunnerInstanceRole
AWS_DEFAULT_VPC_ID=vpc-0d2122788fc944c5c
AWS_DEFAULT_SUBNET_ID=subnet-08a374994d1a8c902
AWS_DEFAULT_SECURITY_GROUP_ID=sg-01014111d2efb1ab2
POV_BOOTSTRAP_REPO_URL=https://github.com/stephenlthorn/tidb-pov-kit-self-service.git
POV_BOOTSTRAP_REPO_REF=main

# Optional dedicated credentials for AWS control-plane actions (AssumeRole + EC2 launch).
# If omitted, the app falls back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
AWS_CONTROL_ACCESS_KEY_ID=
AWS_CONTROL_SECRET_ACCESS_KEY=
AWS_CONTROL_SESSION_TOKEN=

# Optional S3 artifact persistence (PDF/metrics/logs)
S3_ARTIFACTS_ENABLED=true
S3_BUCKET=
S3_PREFIX=tidb-pov
S3_ARTIFACTS_PROJECT=default
S3_REGION=us-east-1
# Credentials for S3 API calls from Vercel functions
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
